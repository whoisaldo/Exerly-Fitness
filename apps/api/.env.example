PORT=3001
JWT_SECRET=your-jwt-secret-here
ADMIN_EMAILS=admin@example.com
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/exerly
AI_API_KEY=your-gemini-api-key

# FatSecret API (optional — barcode lookup falls back to Open Food Facts if missing)
# FATSECRET_CLIENT_ID=your-fatsecret-client-id
# FATSECRET_CLIENT_SECRET=your-fatsecret-client-secret

# Set to "local" to use SQLite + mock AI (no external services needed)
# DB_MODE=local
